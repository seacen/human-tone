{
  "lang": "zh",
  "displayName": "中文",
  "detect": {
    "cjkRatioMin": 0.2
  },
  "signals": [
    {
      "id": "MP-06",
      "label": "万能动词空转",
      "regex": "(进行|作出|加以|予以|给予)\\s*[\\u4e00-\\u9fa5]{1,4}",
      "flags": "g"
    },
    {
      "id": "MP-11",
      "label": "装腔大词",
      "regex": "赋能|抓手|闭环|落地|颗粒度|拉通|对齐|心智|顶层设计|底层逻辑|方法论|组合拳|护城河|价值主张|降维打击",
      "flags": "g"
    },
    {
      "id": "MP-02",
      "label": "机械对举",
      "regex": "不是[^。！？\\n]{0,20}而是|与其说[^。！？\\n]{0,20}不如说",
      "flags": "g"
    },
    {
      "id": "MP-16",
      "label": "冗余范畴壳",
      "regex": "[\\u4e00-\\u9fa5]这种(东西|事)|作为一种",
      "flags": "g"
    },
    {
      "id": "MP-12",
      "label": "死隐喻与拟物化",
      "regex": "长在|长进|长出|长成|长着|托住|接住|兜住|撑住|承接",
      "flags": "g"
    },
    {
      "id": "MP-08",
      "label": "总结书签套话",
      "regex": "综上所述|总而言之|值得一提的是|众所周知|由此可见|在当今[\\u4e00-\\u9fa5]{0,10}的时代|随着[\\u4e00-\\u9fa5]{0,15}的(发展|到来)",
      "flags": "g"
    },
    {
      "id": "MP-04",
      "label": "叙述者导游",
      "regex": "值得注意的是|需要指出的是|让我们[\\u4e00-\\u9fa5]|我们可以看到",
      "flags": "g"
    },
    {
      "id": "ZH-DE-STACK",
      "label": "的的不休",
      "regex": "的的|的[\\u4e00-\\u9fa5]{1,4}的[\\u4e00-\\u9fa5]{1,4}的",
      "flags": "g"
    },
    {
      "id": "ZH-BEI-SUO",
      "label": "被字滥用（被…所…双重被动）",
      "regex": "被[\\u4e00-\\u9fa5]{0,6}所[\\u4e00-\\u9fa5]",
      "flags": "g"
    },
    {
      "id": "MP-03",
      "label": "结构性排比脚手架（密集重复,交模型判稀释）",
      "regex": "一是[\\s\\S]{0,50}二是[\\s\\S]{0,50}三是|首先[\\s\\S]{0,80}其次[\\s\\S]{0,80}(最后|再次|最终)|(不[^，。！？\\n]{1,12}，){2,}不",
      "flags": "g"
    }
  ]
}
